# ---------------------------------------------------------------------------
# AI HomeDesign MCP server — environment configuration
# Copy to `.env` and fill in. NEVER commit your real .env.
# Every variable is optional; the server degrades gracefully when unset.
# ---------------------------------------------------------------------------

# Default/fallback AI HomeDesign x-api-key. In multi-tenant mode each caller
# brings their own key via the connector URL, so this is only a fallback.
# Get a key at https://www.aihomedesign.com
AIHD_API_KEY=

# AI HomeDesign API base URL (override only for testing).
AIHD_API_BASE=https://api.aihomedesign.com/v3

# Port the MCP server listens on.
PORT=8080

# Legacy shared bearer token -> resolves to AIHD_API_KEY (optional, back-compat).
MCP_AUTH_TOKEN=

# --- Persistence (optional): opaque connector tokens + usage log -------------
# Postgres DSN, e.g. postgresql://user:pass@host:5432/dbname
DB_DSN=
# Fernet key used to encrypt each user's API key at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_SECRET=

# Base URL used to build the connector link returned by POST /token,
# e.g. https://mcp.aihomedesign.com  ->  <base>/<token>/mcp
MCP_CONNECTOR_BASE=

# --- Optional built-in image upload hosting ---------------------------------
# When both are set, POST /upload saves an image and returns a public URL.
UPLOAD_DIR=
PUBLIC_BASE=
UPLOAD_URL_PREFIX=/u
